@page "/"
@inject NavigationManager Nav

<PageTitle>Home</PageTitle>

<div class="login-root">

    <!-- Fondo con partículas decorativas -->
    <div class="login-bg">
        <div class="bg-orb orb-1"></div>
        <div class="bg-orb orb-2"></div>
        <div class="bg-orb orb-3"></div>
        <div class="grid-overlay"></div>
    </div>

    <!-- Contenido centrado -->
    <div class="login-content">

        <!-- Brand -->
        <div class="login-brand">
            <div class="brand-mark">
                <svg width="18" height="18" viewBox="0 0 14 14" fill="none">
                    <path d="M7 2L12 11H2L7 2Z" fill="white" opacity=".95" />
                </svg>
            </div>
            <span class="brand-name">Antarez</span>
        </div>

        <!-- Heading -->
        <div class="login-heading">
            <h1 class="login-title">¿Quién eres hoy?</h1>
            <p class="login-sub">Selecciona tu perfil para ingresar al sistema</p>
        </div>

        <!-- Grid de usuarios -->
        <div class="users-grid">
            @foreach (var user in _users)
            {
                <button class="user-card @(user.IsOnline ? "is-online" : "") @(_loading == user.Id ? "is-loading" : "")"
                        @onclick="() => LoginAs(user)"
                        disabled="@(_loading != null)">

                    <!-- Indicador de carga -->
                    <div class="card-loading-bar"></div>

                    <!-- Avatar con indicador online -->
                    <div class="uc-avatar-wrap">
                        <div class="uc-avatar" style="background: linear-gradient(135deg, @user.ColorLight, @user.ColorDark)">
                            @user.Initials
                        </div>
                        @if (user.IsOnline)
                        {
                            <div class="uc-online-dot"></div>
                        }
                    </div>

                    <!-- Info -->
                    <div class="uc-info">
                        <div class="uc-name">@user.Name</div>
                        <div class="uc-role">@user.Role</div>
                    </div>

                    <!-- Status badge -->
                    <div class="uc-status">
                        @if (user.IsOnline)
                        {
                            <span class="status-badge online">
                                <span class="status-dot"></span>
                                Conectado
                            </span>
                        }
                        else
                        {
                            <span class="status-badge offline">Fuera de línea</span>
                        }
                    </div>

                    <!-- Flecha hover -->
                    <div class="uc-arrow">
                        <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor"
                                  stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </div>
                </button>
            }
        </div>

        <!-- Footer note -->
        <p class="login-footer">
            <svg width="11" height="11" viewBox="0 0 16 16" fill="none" style="opacity:.5">
                <rect x="3" y="7" width="10" height="8" rx="2" stroke="currentColor" stroke-width="1.2" />
                <path d="M5 7V5a3 3 0 0 1 6 0v2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
            </svg>
            Entorno de demostración — acceso sin contraseña
        </p>
    </div>
</div>

@code {
    private string? _loading;

    // Modelo de usuario de demo — reemplazar con llamada real a IUserService
    private readonly List<DemoUser> _users = new()
    {
        new() { Id="aj", Name="Angelina Jolie",   Initials="AJ", Role="Administradora",   ColorLight="#7F77DD", ColorDark="#534AB7", IsOnline=true  },
        new() { Id="lm", Name="Luis Mendoza",      Initials="LM", Role="Coordinador",      ColorLight="#4a7dbd", ColorDark="#2d4a6a", IsOnline=true  },
        new() { Id="sc", Name="Sofía Castro",      Initials="SC", Role="Docente",           ColorLight="#7F77DD", ColorDark="#534AB7", IsOnline=true  },
        new() { Id="rg", Name="Ramón García",      Initials="RG", Role="Docente",           ColorLight="#4db87a", ColorDark="#3a5a3a", IsOnline=false },
        new() { Id="vt", Name="Valentina Torres",  Initials="VT", Role="Estudiante",        ColorLight="#e0a040", ColorDark="#854F0B", IsOnline=false },
        new() { Id="ep", Name="Emilio Pérez",      Initials="EP", Role="Estudiante",        ColorLight="#25c4a0", ColorDark="#0F6E56", IsOnline=true  },
    };

    private async Task LoginAs(DemoUser user)
    {
        _loading = user.Id;
        StateHasChanged();

        // ── Aquí va tu lógica real de autenticación ──
        // Ejemplo con IUserService + cookie / JWT:
        //   await UserSvc.SignInAsync(user.Id);
        //   Nav.NavigateTo("/perfil", forceLoad: true);

        await Task.Delay(900); // simula la llamada a la API
        Nav.NavigateTo("/perfil", forceLoad: true);
    }

    private record DemoUser
    {
        public string Id { get; init; } = "";
        public string Name { get; init; } = "";
        public string Initials { get; init; } = "";
        public string Role { get; init; } = "";
        public string ColorLight { get; init; } = "#7F77DD";
        public string ColorDark { get; init; } = "#534AB7";
        public bool IsOnline { get; init; }
    }
}

